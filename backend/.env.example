PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

JWT_SECRET=change_this_to_a_secure_random_secret
JWT_EXPIRES_IN=1d

MONGODB_URI=mongodb://localhost:27017/cricket_organizer

ADMIN_EMAIL=admin@cricket.local
ADMIN_PASSWORD=Admin@123

# Optional comma-separated role mapping by email (applied at login)
ORGANIZER_EMAILS=
PLAYER_EMAILS=

# OTP settings
OTP_EXPIRY_MINUTES=10

# Live cricket API provider settings
CRICAPI_KEY=
CRICAPI_BASE_URL=https://api.cricapi.com/v1
