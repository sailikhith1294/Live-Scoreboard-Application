# ============================================
# CREASE Frontend Environment Configuration
# Microservices Architecture
# ============================================

# API Gateway URL (routes to microservices)
VITE_API_URL=http://localhost:3000/api

# Socket.io Server URL (for real-time updates)
VITE_SOCKET_URL=http://localhost:3000

# ============================================
# Production Configuration (when deploying)
# ============================================
# VITE_API_URL=https://your-backend-domain.com/api
# VITE_SOCKET_URL=https://your-backend-domain.com

# ============================================
# Notes:
# ============================================
# - All Vite environment variables must start with VITE_
# - Update these URLs when deploying to production
# - Make sure backend CORS is configured to allow frontend URL
# ============================================
